<h2>User info</h2>

<%= image_tag user.get_profile_image(100, 100), size: "100x100" %>
<table class="table border-top ">
  <tr>
    <th>name</th>
    <th><%=user.name %></th>
  </tr>
  <tr>
    <th>introduction</th>
    <th><%= user.introduction %></th>
  </tr>
  <tr>
    <th>follows</th>
    <th><%= link_to user.followings.count, followings_user_path(user),
        class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %></th>
  </tr>
  <tr>
    <th>followers</th>
    <th><%= link_to user.followers.count, followers_user_path(user),
        class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %></th>
  </tr>
</table>

<div class='row'>
  <% if user == Current.user %>
    <%= link_to edit_user_path(user), class: "btn btn-outline-secondary btn-block" do %>
      <i class="fas fa-user-cog"></i>
    <% end %>
  <% else %>
    <% if Current.user.active_relationships.exists?(followed_id: user.id) %>
      <%= link_to "フォロー外す", user_relationships_path(user), data: { turbo_method: :delete }, class: "btn btn-info" %>
    <% else %>
      <%= link_to "フォローする", user_relationships_path(user), data: { turbo_method: :post }, class: "btn btn-success" %>
    <% end %>
  <% end %>
</div>



<h2 class="mt-3">New book</h2>

  <%= form_with model: book, local: true, data: { turbo: false } do |f| %>
    <div class="form-group">
      <label for="book_title">Title</label>
      <%= f.text_field :title, class: 'form-control' %>
    </div>
    <div class="form-group">
      <label for="book_opinion">Opinion</label>
      <%= f.text_area :body, class: 'form-control' %>
    </div>

    <div class="form-group">
      <%= f.submit 'Create Book', class: 'btn btn-success' %>
    </div>
  <% end %>