<%= flash[:notice] %>

<div class="container px-5 px-sm-0">

  <div class="row">
    <div class="col-md-3">
      <%= render 'users/info', user: @user, book: @book %>
  
    </div>
    
    <div class="col-md-8 offset-md-1">
      <h2>Books</h2>

      <table class="table border-top table-hover">
      <thead>
        <th></th>
        <th>Title</th>
        <th>Opinion</th>
      </thead>
      <tbody>

        <% @books.each do |book| %>
          <tr>
            <td>
            <%= link_to user_path(book.user) do %>
            <%= image_tag book.user.get_profile_image(80, 80) %>
            <% end %>
            </td>
            <td><%= link_to book.title, book_path(book.id) %></td>
            <td><%= book.body %></td>
          </tr>
        <% end %>
        
          <table class="table table-bordered">
            <thead>
            <h3>投稿数の前日比・前週比</h3>
              <tr>
                <th>今日の投稿数</th>
                <th>前日の投稿数</th>
                <th>前日比</th>
              </tr>
            </thead>
            
            <tbody>
              <tr>
                <td><%= @today_book.count %></td>
                <td><%= @yesterday_book.count %></td>
                <td>
                  <% if @yesterday_book.count == 0 %>
                    前日の投稿がないため計算できません
                  <% else %>
                    <% @the_day_before = @today_book.count / @yesterday_book.count.to_f %>
                    <%= (@the_day_before * 100).round %>%
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>

          <table class="table table-bordered">
            <thead>
              <tr>
                <th>今週の投稿数</th>
                <th>先週の投稿数</th>
                <th>前週比</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= @this_week_book.count %></td>
                <td><%= @last_week_book.count %></td>
                <td>
                  <% if @last_week_book.count == 0 %>
                    先週の投稿がないため計算できません
                  <% else %>
                    <% @the_week_before = @this_week_book.count / @last_week_book.count.to_f %>
                    <%= (@the_week_before * 100).round %>%
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>

<%= form_with url: search_user_path(@user), method: :get, local: false, class: "mb-3" do |f| %>
  <%= f.date_field :created_at, class: "form-control d-inline-block", style: "width: auto;" %>
  <%= f.submit '検索', class: 'btn btn-primary' %>
<% end %>

<div id="search_result">
  <% if @search_book.present? %>
    <%= render 'search_result', search_book: @search_book %>
  <% end %>
</div>



      </tbody>
      </table>


      </div>
  </div>
</div>