<div class="container px-5 px-sm-0">

  <div class="row">
    <div class="col-md-3">
      <%= render 'users/info', user: Current.user, book: @book %>
    </div>
    
    <div class="col-md-8 offset-md-1">
      <h2>Users</h2>
      <%= link_to 'グループを作成する', new_group_path,
      class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %> |
      <%= link_to 'グループ一覧', groups_path,
      class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %>


  <table class="table border-top">
    <thead>
      <tr>
        <th>image</th>
        <th>name</th>
        <th colspan="3"></th>
        <th colspan="3"></th>
        <th colspan="3"></th>
        <th colspan="3"></th>
      </tr>
    </thead>
      <tbody class="table-group-divider border-light-subtle">
        <% @users.each do |user| %>
          <tr>
            <td><%= image_tag user.get_profile_image(80,80) %></td>
            <td><%= user.name %></td>
            <td>フォロー数: <%= user.followings.count %></td>
            <td>フォロワー数: <%= user.followers.count %></td>
            <td>
              <% if user != Current.user %>
                <% if Current.user.active_relationships.exists?(followed_id: user.id) %>
                  <%= link_to "フォロー外す", user_relationships_path(user), data: { turbo_method: :delete },
                  class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %>
                <% else %>
                  <%= link_to "フォローする", user_relationships_path(user), data: { turbo_method: :post },
                  class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %>
                <% end %>
              <% end %>
            </td>
            <td><%= link_to "Show", user_path(user.id),
            class: "link-offset-0 link-offset-0-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover" %></td>
          </tr>
        <% end %>
      </tbody>
      </table>

</div>
</div>
</div>