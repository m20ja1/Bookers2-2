<div class="container px-5 px-sm-0">

  <div class="row">
    <div class="col-md-3">
      <%= render 'users/info', user: Current.user, book: @book %>
    </div>
    
    <div class="col-md-8 offset-md-1">
      <h2>Users</h2>


  <table class="table border-top">
    <thead>
      <tr> <th>image</th>
      <th>name</th>
      <th colspan="3"></th> </tr>
    </thead>
      <tbody class="table-group-divider border-light-subtle">
        <% @users.each do |user| %>
          <tr>
            <td><%= image_tag user.get_profile_image(80,80) %></td>
            <td><%= user.name %></td>
            <td><%= link_to "Show", user_path(user.id) %></td>
          </tr>
        <% end %>
      </tbody>
      </table>

</div>
</div>
</div>