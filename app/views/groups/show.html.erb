<div class='container px-5 px-sm-0'>
  <div class='row'>
    <div class='col-md-3'>
      <h2>User info</h2>
      <%= render 'users/info', user: Current.user, book: @book %>
    </div>

    <div class='col-md-8 offset-md-1'>
      <h2>Group Detail</h2>
      <table class='table table-hover table-inverse'>
        <thead>
          <tr>
            <th></th>
            <th>グループ名</th>
            <th>紹介文</th>
            <th>メンバー</th>
            <th>メンバー数</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <% if @group.image.attached? %>
                <%= image_tag @group.image, size: "50x50" %>
              <% else %>
                <%= image_tag 'no_image.jpg', size: "50x50" %>
              <% end %>
            </td>
            <td><%= @group.name %></td>
            <td><%= @group.introduction %></td>
            <td>
                <ul style="padding-left: 0;">
                <% @group.users.each do |user| %>
                  <li style="list-style: none;"><%= user.name %></li>
                <% end %>
              </ul>
            </td>
            <td>
              <%= @group.users.count %>
            </td>
            <td>
              <% if @group.owner_id == Current.user.id %>
                <%= link_to 'Edit', edit_group_path(@group), class: "btn btn-sm btn-success" %>
                <%= link_to 'Notice an Event', new_group_event_notices_path(@group), class: "btn btn-sm btn-info ml-2" %>
              <% elsif @group.users.include?(Current.user) %>
                <%= link_to 'Leave this group', group_group_users_path(@group), data: { turbo_method: :delete }, class: "btn btn-sm btn-danger" %>
              <% else %>
                <%= link_to 'Join this group', group_group_users_path(@group), data: { turbo_method: :post }, class: "btn btn-sm btn-primary" %>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>